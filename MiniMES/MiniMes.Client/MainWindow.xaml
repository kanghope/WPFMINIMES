<Window x:Class="MiniMes.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mini MES System" Height="650" Width="1100">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="./Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Background="#F0F0F0">
            <StackPanel DockPanel.Dock="Top" VerticalAlignment="Bottom" Margin="10">
                <Separator Margin="0,10" Background="#DDD"/>
                <StackPanel Orientation="Horizontal" Margin="5,2">
                    <Ellipse Width="10" Height="10" Fill="LimeGreen" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtUserRole" Text="관리자" FontSize="11" Foreground="#666" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock x:Name="TxtUserName" Text="홍길동 님" FontSize="13" Margin="23,0,0,5" Foreground="#333"/>
                <Button Content="로그아웃" Click="OnLogoutClick" Height="25" Margin="5" Background="Transparent" BorderBrush="#CCC" FontSize="11"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="top">
                <TextBlock Text="Mini MES" FontSize="20" Margin="10" HorizontalAlignment="Center" Foreground="#333" FontWeight="Bold"/>
                <Button Style="{StaticResource MetroBlueButtonStyle}" Content="실시간 대시보드" 
                        Margin="5" Height="45" Click="OnOpenDashboardClick"/>
                <Button Style="{StaticResource MetroBlueButtonStyle}" Content="작업 지시 관리" Margin="5" Height="40" Click="OnOpenWorkOrderClick"/>
                <Button Style="{StaticResource MetroBlueButtonStyle}" Content="재고 관리(미구현)" Margin="5" Height="40"/>
            </StackPanel>

            

            <Grid />
        </DockPanel>
        <Border Grid.Column="1" Background="#FFFFFF" Margin="5" CornerRadius="5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#EEE"/>
            </Border.Effect>
            <ContentControl x:Name="MainContent" Margin="10"/>
        </Border>

   
    </Grid>
</Window>