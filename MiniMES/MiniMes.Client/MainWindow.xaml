<Window x:Class="MiniMes.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mini MES System" Height="600" Width="1000">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="./Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#F0F0F0">
            <TextBlock Text="Mini MES" FontSize="20" Margin="10" HorizontalAlignment="Center"/>
            <Button Style="{StaticResource MetroBlueButtonStyle}" Content="작업 지시 관리" Margin="5" Height="40" Click="OnOpenWorkOrderClick"/>
            <Button Style="{StaticResource MetroBlueButtonStyle}" Content="재고 관리(미구현)" Margin="5" Height="40"/>
        </StackPanel>

        <ContentControl x:Name="MainContent" Grid.Column="1" Margin="10"/>
    </Grid>
</Window>