<UserControl x:Class="MiniMes.Client.Views.ItemManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MiniMes.Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vm:ItemManagementViewModel, IsDesignTimeCreatable=False}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <Style x:Key="ItemTypeStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ItemType}" Value="FG">
                        <Setter Property="Foreground" Value="#2980B9"/>
                        <Setter Property="Text" Value="완제품(FG)"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ItemType}" Value="RM">
                        <Setter Property="Foreground" Value="#27AE60"/>
                        <Setter Property="Text" Value="원자재(RM)"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#F9F9F9" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="15,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="품목 구분:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                    <ComboBox Width="120" Height="28" 
                              SelectedValue="{Binding SelectedTypeFilter}" 
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="전체보기" Tag="ALL" IsSelected="True"/>
                        <ComboBoxItem Content="완제품(FG)" Tag="FG"/>
                        <ComboBoxItem Content="원자재(RM)" Tag="RM"/>
                    </ComboBox>

                    <TextBlock Text="검색어:" VerticalAlignment="Center" Margin="20,0,10,0" FontWeight="SemiBold"/>
                    <TextBox Width="250" Height="28" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="품목 코드 또는 품목명 입력..."
                             HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Content="🔍 조회" 
                            Command="{Binding SearchCommand}" 
                            Style="{StaticResource MetroBlueButtonStyle}"
                            Width="80" Height="28" Margin="10,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔄 새로고침" Command="{Binding LoadCommand}" 
                            Style="{StaticResource MetroBlueButtonStyle}" Margin="5,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="#E9ECEF" Padding="15,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📋 품목 마스터 현황:" FontWeight="Bold" Foreground="#444444"/>
                <TextBlock Text="{Binding StatisticsSummary}" Margin="10,0,0,0" Foreground="#666666"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding Items}" 
                  SelectedItem="{Binding SelectedItem}"
                  Style="{StaticResource MetroDataGridStyle}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="False" 
                  SelectionMode="Single"
                  Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="품목 코드" Binding="{Binding ItemCode}" Width="150" IsReadOnly="False">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource CenterTextColumnStyle}"/>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="품목 명칭" Binding="{Binding ItemName}" Width="*" IsReadOnly="False">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="10,0,0,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="품목 타입" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource ItemTypeStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedValue="{Binding ItemType, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="완제품(FG)" Tag="FG"/>
                                <ComboBoxItem Content="원자재(RM)" Tag="RM"/>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridCheckBoxColumn Header="사용 여부" Binding="{Binding IsActive}" Width="80">
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>

                    <DataGridCheckBoxColumn.EditingElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.EditingElementStyle>

                </DataGridCheckBoxColumn>
                <DataGridTextColumn Header="단위" Binding="{Binding ItemUnit}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource CenterTextColumnStyle}"/>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="규격" Binding="{Binding ItemSpec}" Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource CenterTextColumnStyle}"/>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="#F0F0F0" Padding="10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="➕ 신규 등록" Command="{Binding AddCommand}" 
                            Style="{StaticResource MetroBlueButtonStyle}" Width="100" Height="32" Margin="0,0,5,0"/>
                    <Button Content="🗑 선택 삭제" Command="{Binding DeleteCommand}" 
                            Style="{StaticResource MetroPinkButtonStyle}" Width="100" Height="32"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="💾 변경사항 저장" Command="{Binding SaveCommand}" 
                            Style="{StaticResource MetroBlueButtonStyle}" 
                            Width="150" Height="32" FontWeight="Bold"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.RowSpan="4" Background="#88FFFFFF" 
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Border Background="White" BorderBrush="#0078D7" BorderThickness="1" 
                    VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Padding="40,30" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.2" ShadowDepth="3"/>
                </Border.Effect>

                <StackPanel Width="320">
                    <TextBlock Text="데이터를 처리하고 있습니다" FontSize="16" FontWeight="Bold" 
                               Foreground="#333333" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <ProgressBar Value="{Binding LoadingProgress}" 
                                 Minimum="0" Maximum="100" 
                                 Height="12" Foreground="#0078D7" Background="#EEEEEE"/>

                    <DockPanel Margin="0,5,0,0">
                        <TextBlock Text="{Binding StatisticsSummary}" FontSize="11" Foreground="#666666"/>
                        <TextBlock Text="{Binding LoadingProgress, StringFormat={}{0:F0}%}" 
                                   HorizontalAlignment="Right" Foreground="#0078D7" 
                                   FontSize="12" FontWeight="Bold"/>
                    </DockPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>