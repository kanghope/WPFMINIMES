<UserControl x:Class="MiniMes.Client.Views.WorkOrderListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MiniMes.Client.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:WorkOrderListViewModel, IsDesignTimeCreatable=False}"> 
    <!-- Title="MES 작업 지시 관리" Height="450" Width="800"-->
    <!--<UserControl.DataContext>
        <vm:WorkOrderListViewModel/>
    </UserControl.DataContext>-->
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            
            <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource MetroTextBoxStyle}">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>

    </UserControl.Resources>
    <Grid Cursor="">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="10" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="조회 기간 :" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <DatePicker SelectedDate="{Binding StartDate}" Width="120" Height="25"/>
            <TextBlock Text="~" VerticalAlignment="Center" Margin="5,0"/>
            <DatePicker SelectedDate="{Binding EndDate}" Width="120" Height="25"/>

            <TextBlock Text="상태 :" VerticalAlignment="Center" Margin="15,0,5,0"/>
            <ComboBox ItemsSource="{Binding StatusOptions}" 
              SelectedValue="{Binding SelectedStatusCode}"
              DisplayMemberPath="DisplayName"
              SelectedValuePath="StatusCode"
              Width="100" Height="25"
              VerticalContentAlignment="Center"/>

            <TextBlock Text="검색어 :" VerticalAlignment="Center" Margin="15,0,5,0"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
             Width="150" Height="25" 
             Tag="품목코드 또는 ID 입력...">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding LoadCommand}"/>
                </TextBox.InputBindings>
            </TextBox>

            <Button Content="🔍 조회" 
            Command="{Binding LoadCommand}" 
            Margin="10,0,0,0" 
            Padding="10,0" 
            Height="25"
            Style="{StaticResource MetroBlueButtonStyle}"/>
        </StackPanel>
        <Border Grid.Row="1" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="15,7">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📊 생산 현황 요약:" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatisticsSummary}" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#555555"/>
            </StackPanel>
        </Border>
        <DataGrid Grid.Row="2" 
                  Sorting="DataGrid_Sorting" 
                  Style="{StaticResource MetroDataGridStyle}"
                  ItemsSource="{Binding WorkOrders}" 
                  SelectedItem="{Binding SelectedWorkOrder}" 
                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                  
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  VirtualizingStackPanel.CacheLengthUnit="Item"
                  VirtualizingStackPanel.CacheLength="10,10"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  >
            <DataGrid.Columns>
                <DataGridTextColumn ElementStyle="{StaticResource CenterTextColumnStyle}" Header="지시 ID" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn   Header="품목 코드"  Binding="{Binding ItemCode}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn ElementStyle="{StaticResource CenterTextColumnStyle}" Header="계획 수량" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn ElementStyle="{StaticResource CenterTextColumnStyle}" Header="실적 수량" Binding="{Binding CompleteQty}" Width="80"/>
                <DataGridTemplateColumn Header="진행률" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="5,2">
                                <ProgressBar Value="{Binding ProgressValue, Mode=OneWay}" Minimum="0" Maximum="100" Height="14" Foreground="#4CAF50" Background="#E0E0E0"/>
                                <TextBlock Text="{Binding ProgressValue, StringFormat={}{0}%}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn  Header="상태" Binding="{Binding DisplayStatus}"  Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="P">
                                    <Setter Property="Foreground" Value="LightGreen"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="C">
                                    <Setter Property="Foreground" Value="Blue"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="W">
                                    <Setter Property="Foreground" Value="LightPink"/>
                                </DataTrigger>
                            </Style.Triggers>
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="합계 계산" Command="{Binding CalculateStatsCommand}" Margin="5" MinWidth="70" Cursor="Hand" Style="{StaticResource MetroBlueButtonStyle}"/>
            <Button Content="새로 고침" Command="{Binding LoadCommand}" Margin="5" MinWidth="70" Cursor="Hand" Style="{StaticResource MetroBlueButtonStyle}"/>
            <Button Content="지시 등록" Command="{Binding AddCommand}" Margin="5" Height="30" MinWidth="70" Cursor="Hand" Style="{StaticResource MetroBlueButtonStyle}"/>
            <Button Content="지시 수정" Command="{Binding EditCommand}" Margin="5" MinWidth="70" Cursor="Hand" Style="{StaticResource MetroBlueButtonStyle}"/>
            <Button Content="지시 삭제" Command="{Binding DeleteCommand}" Margin="5" MinWidth="70" Cursor="Hand" Style="{StaticResource MetroBlueButtonStyle}"/>
            <Separator Margin="10,0"/>
            <!--Button Content="작업 시작" Command="{Binding StartWorkCommand}" Margin="5" MinWidth="70" Cursor="Hand" Style="{StaticResource MetroBlueButtonStyle}"/-->
            <Button Content="작업 시작(PLC)" Command="{Binding StartCommand}" 
                    Margin="5" MinWidth="100" FontWeight="Bold" Background="#27AE60" Foreground="White"
                    Style="{StaticResource MetroBlueButtonStyle}"/>

            <Button Content="작업 종료(PLC)" Command="{Binding StopCommand}" 
                    Margin="5" MinWidth="100" FontWeight="Bold" Background="#C0392B" Foreground="White"
                    Style="{StaticResource MetroBlueButtonStyle}"/>
            <Button Content="실적 등록/완료" Command="{Binding RegisterResultCommand}" Margin="5" MinWidth="120" Cursor="Hand" Style="{StaticResource MetroBlueButtonStyle}"/>
            <Button Content="실적 조회" Command="{Binding ViewResultsCommand}" Margin="5" MinWidth="70" Cursor="Hand" Style="{StaticResource MetroBlueButtonStyle}" />
        </StackPanel>
        <Grid Grid.Row="0" Grid.RowSpan="4" Background="#AAFFFFFF" 
      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">

            <Border Background="White" BorderBrush="#0078D7" BorderThickness="1" 
            VerticalAlignment="Center" HorizontalAlignment="Center" 
            Padding="40,30" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.2" ShadowDepth="3"/>
                </Border.Effect>

                <StackPanel Width="300">
                    <TextBlock Text="데이터 처리 및 통신 준비 중" FontSize="16" FontWeight="Bold" 
                       Foreground="#333333" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <ProgressBar Value="{Binding LoadingProgress}" 
                         Minimum="0" Maximum="100" 
                         IsIndeterminate="False" 
                         Height="12" Foreground="#0078D7" Background="#EEEEEE">
                    </ProgressBar>

                    <TextBlock Text="{Binding LoadingProgress, StringFormat={}{0:F0}%}" 
                       HorizontalAlignment="Right" Foreground="#0078D7" 
                       FontSize="12" FontWeight="Bold" Margin="0,5,0,0"/>

                    <TextBlock Text="{Binding StatisticsSummary}" 
                       Margin="0,20,0,0" HorizontalAlignment="Center" 
                       FontSize="11" Foreground="#666666"/>
                </StackPanel>
            </Border>
        </Grid>
        <GroupBox Grid.Row="5" Header="📡 PLC 실시간 통신 로그" Margin="5" BorderBrush="#CCCCCC">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <ListBox Grid.Column="0" 
                         ItemsSource="{Binding CommunicationLogs}" 
                         Background="#1E1E1E" Foreground="#00FF00" 
                         FontSize="11" FontFamily="Consolas" BorderThickness="0"/>

                <Border Grid.Column="1" Background="#F8F9FA" BorderBrush="#DDDDDD" BorderThickness="1,0,0,0">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Width="12" Height="12" Fill="{Binding DeviceStatusColor}" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding DeviceStatusText}" FontWeight="Bold"/>
                        </StackPanel>

                        <Separator Margin="0,5"/>

                        <TextBlock Text="마지막 수신 시간:" FontSize="10" Foreground="#666666"/>
                        <TextBlock Text="{Binding LastSignalTime}" FontWeight="SemiBold" Margin="0,0,0,5"/>

                        <TextBlock Text="누적 패킷량:" FontSize="10" Foreground="#666666"/>
                        <TextBlock Text="{Binding PacketCount, StringFormat={}{0} 건}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </GroupBox>
        <!--
        <Grid Grid.Row="0" Grid.RowSpan="3" Background="#AAFFFFFF" 
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Border Background="White" BorderBrush="#0078D7" BorderThickness="1" 
                    VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30" CornerRadius="5">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Width="250" Height="5" Foreground="#0078D7" Background="#EEEEEE"/>
                    <TextBlock Text="대용량 데이터를 분석하고 있습니다..." 
                               Margin="0,15,0,0" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#333333"/>
                    <TextBlock Text="잠시만 기다려 주십시오." 
                               FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center" Foreground="#888888"/>
                </StackPanel>
            </Border>
        </Grid>
-->
    </Grid>
    

</UserControl>