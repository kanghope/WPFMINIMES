<Window x:Class="MiniMes.Client.Views.WorkResultListView"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="작업 실적 조회" Height="400" Width="600"

        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10" Orientation="Vertical" Background="#EEEEEE" >

            <TextBlock FontWeight="Bold" FontSize="14" Text="{Binding ItemCode, StringFormat='품목 코드: {0}'}"/>

            <StackPanel Orientation="Horizontal">

                <TextBlock Text="{Binding WorkOrderId, StringFormat='지시 ID: {0}'}" Margin="0,5,20,0"/>

                <TextBlock Text="{Binding OrderQuantity, StringFormat='지시 수량: {0}'}" Margin="0,5,20,0"/>

                <TextBlock Text="{Binding WorkOrderStatus, StringFormat='현재 상태: {0}'}" FontWeight="SemiBold" Margin="0,5,0,0"/>

            </StackPanel>

        </StackPanel>

        <DataGrid Grid.Row="1"

                  ItemsSource="{Binding Results}"

                  AutoGenerateColumns="False" 

                  IsReadOnly="True" 

                  SelectionMode="Single"

                  HeadersVisibility="Column">

            <DataGrid.Columns>

                <DataGridTextColumn Header="실적 ID" Binding="{Binding ResultId}" Width="60"/>

                <DataGridTextColumn Header="양품 수량" Binding="{Binding GoodQuantity}" Width="*"/>

                <DataGridTextColumn Header="불량 수량" Binding="{Binding BadQuantity}" Width="*"/>

                <DataGridTextColumn Header="등록 시간" Binding="{Binding ResultDate, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="2*"/>

            </DataGrid.Columns>

        </DataGrid>



        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">

            <Button Content="새로 고침" Command="{Binding LoadResultsCommand}" Margin="5" Padding="10,5"/>

            <Button Content="닫기" IsCancel="True" Padding="10,5"/>

        </StackPanel>

    </Grid>

</Window>