<Window x:Class="MiniMes.Client.Views.WorkResultRegisterView"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="작업 실적 등록" Height="300" Width="400"

        WindowStartupLocation="CenterScreen">



    <Grid Margin="15">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="Auto"/>

            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>



        <TextBlock Grid.Row="0" Grid.Column="0" Text="품목 코드:" Margin="5" VerticalAlignment="Center" FontWeight="Bold"/>

        <TextBlock Grid.Row="0" Grid.Column="1" Margin="5" Text="{Binding ItemCode}" VerticalAlignment="Center"/>



        <TextBlock Grid.Row="1" Grid.Column="0" Text="지시 수량:" Margin="5" VerticalAlignment="Center" FontWeight="Bold"/>

        <TextBlock Grid.Row="1" Grid.Column="1" Margin="5" Text="{Binding OrderQuantity}" VerticalAlignment="Center"/>



        <Separator Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,10"/>



        <TextBlock Grid.Row="3" Grid.Column="0" Text="양품 수량 (Good):" Margin="5" VerticalAlignment="Center"/>

        <TextBox Grid.Row="3" Grid.Column="1" Margin="5" Text="{Binding GoodQuantity, UpdateSourceTrigger=PropertyChanged}"/>



        <TextBlock Grid.Row="4" Grid.Column="0" Text="불량 수량 (Bad):" Margin="5" VerticalAlignment="Center"/>

        <TextBox Grid.Row="4" Grid.Column="1" Margin="5" Text="{Binding BadQuantity, UpdateSourceTrigger=PropertyChanged}"/>



        <TextBlock Grid.Row="5" Grid.ColumnSpan="2" Margin="5" Foreground="Red" Text="{Binding ValidationMessage}"/>



        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">

            <Button Content="실적 저장 및 완료" Margin="5" Padding="15,5" Click="SaveButton_Click" 

                    IsEnabled="{Binding RegisterCommand.CanExecute}"/>

            <Button Content="취소" Margin="5" Padding="15,5" Click="CancelButton_Click"/>

        </StackPanel>

    </Grid>

</Window>